# All variables are required. The app will not start if any are missing.
# Copy this file to .env.local for local development and fill in real values.

# Cloudflare Worker: admin CRUD (list/add/remove admins)
VITE_ADMIN_WORKER_URL=https://your-admin-worker.example.com

# Cloudflare Worker: R2 media (list/upload/delete)
VITE_MEDIA_WORKER_URL=https://your-media-worker.example.com

# Cloudflare Worker: membership (subscribe/approve/reject/renew)
VITE_MEMBERSHIP_WORKER_URL=https://your-membership-worker.example.com

# Cloudflare Worker: event registrations (list/confirm/cancel)
VITE_EVENTS_WORKER_URL=https://your-events-worker.example.com

# Sveltia CMS auth worker base URL
VITE_OAUTH_URL=https://your-auth-worker.example.com

# Site ID passed to the OAuth flow. Must be allowed by the auth worker.
VITE_OAUTH_SITE_ID=your-site.example.com
