# All variables are required — the app will not start if any are missing.
# Copy this file to .env.local and fill in all values.

# Cloudflare Worker: admin CRUD (list/add/remove admins)
VITE_ADMIN_WORKER_URL=https://cms-admin.e-anandraj.workers.dev

# Cloudflare Worker: R2 media (list/upload/delete)
VITE_MEDIA_WORKER_URL=https://cms-media.e-anandraj.workers.dev

# Cloudflare Worker: membership (subscribe/approve/reject/renew)
VITE_MEMBERSHIP_WORKER_URL=https://cms-membership-theme2.e-anandraj.workers.dev

# Cloudflare Worker: event registrations (list/confirm/cancel)
VITE_EVENTS_WORKER_URL=https://cms-events-theme2.e-anandraj.workers.dev

# Sveltia CMS auth worker base URL
VITE_OAUTH_URL=https://sveltia-cms-auth.e-anandraj.workers.dev

# Site ID passed to the OAuth flow — must match the Hugo site hostname
VITE_OAUTH_SITE_ID=anand-raj.github.io
